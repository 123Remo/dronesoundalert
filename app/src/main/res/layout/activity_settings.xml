<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alert_functions"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Global Timing Settings Moved to Top -->
        <TextView
            android:id="@+id/label_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_delay"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seek_alert_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="29"
            android:progress="0"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/label_cooldown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_cooldown"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seek_cooldown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="29"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#eee"
            android:layout_marginBottom="16dp"/>

        <!-- Individual Alert Toggles -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_sound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sound_alert" />

        <Button
            android:id="@+id/btnSelectSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_sound"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/textSelectedSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/default_val"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"
            android:paddingStart="8dp"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/light_alert" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_vibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vibration_alert" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ccc"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Bluetooth Alert -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bluetooth_alert"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_bluetooth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bluetooth_on" />

        <Button
            android:id="@+id/btnBluetoothPair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bluetooth_pair"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <TextView
            android:id="@+id/textBluetoothStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/none_val"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:paddingStart="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/bluetooth_message_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_bluetooth_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ccc"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- SMS settings -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_sms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sms_alert" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sms_numbers_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_sms_numbers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ccc"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Email settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_alert"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/email_alert_on" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_email_gps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_gps_email" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_email_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_time_email" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_email_google_maps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_google_maps" />

        <RadioGroup
            android:id="@+id/radioGroupEmailMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <RadioButton
                android:id="@+id/radioSendGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sendgrid_api"
                android:checked="true" />
            <RadioButton
                android:id="@+id/radioSmtp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/standard_smtp" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/email_addresses_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_email_addresses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SendGrid -->
        <LinearLayout
            android:id="@+id/layoutSendGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/api_key_hint"
                app:passwordToggleEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
            <Button
                android:id="@+id/btnLoadApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/load_api_key"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

        <!-- SMTP -->
        <LinearLayout
            android:id="@+id/layoutSmtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/smtp_host_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_smtp_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/smtp_port_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_smtp_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_smtp_tls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/use_tls" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_smtp_starttls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/use_starttls" />
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/username_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_smtp_user"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/password_hint"
                app:passwordToggleEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_smtp_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sender_name_hint"
            android:layout_marginTop="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_email_sender_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/email_subject_hint"
            android:layout_marginTop="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_email_subject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ccc"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Rsyslog -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rsyslog_alert_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_rsyslog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rsyslog_alert_switch" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_rsyslog_tls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rsyslog_tls" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_rsyslog_gps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_gps_rsyslog" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_rsyslog_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_time_rsyslog" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_rsyslog_debug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/include_debug_rsyslog" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Format"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/radioGroupRsyslogFormat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <RadioButton
                android:id="@+id/radioRsyslogNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Normal (RFC5424)" />
            <RadioButton
                android:id="@+id/radioRsyslogJson"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JSON"
                android:checked="true" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/rsyslog_host_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_rsyslog_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/rsyslog_port_hint"
            android:layout_marginTop="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_rsyslog_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnLoadCertificate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/load_cert"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <TextView
            android:id="@+id/textCertificateStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cert_not_loaded"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:paddingStart="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ccc"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnViewEmailLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/view_email_logs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#FF5722"/>

            <Button
                android:id="@+id/btnViewRsyslogLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/view_rsyslog_logs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#FF5722"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnTestAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_alert"
            android:layout_marginTop="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_settings"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
