<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">


    <LinearLayout
        android:id="@+id/layout_indicators"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">
            <View
                android:id="@+id/dot_red"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_indicator"
                android:alpha="0.2" />
            <TextView
                android:id="@+id/label_red"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/indicator_drone_detected"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:alpha="0.2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">
            <View
                android:id="@+id/dot_yellow"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_indicator"
                android:alpha="0.2" />
            <TextView
                android:id="@+id/label_yellow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/indicator_analyzing"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:alpha="0.2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View
                android:id="@+id/dot_green"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_indicator"
                android:alpha="0.2" />
            <TextView
                android:id="@+id/label_green"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/indicator_listening"
                android:textSize="10sp"
                android:layout_marginStart="4dp"
                android:alpha="0.2" />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layout_indicators"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Left Y-axis (Magnitude) -->
                <ImageView
                    android:id="@+id/axis_y"
                    android:layout_width="30dp"
                    android:layout_height="220dp"
                    android:layout_alignParentStart="true"
                    android:scaleType="fitXY" />

                <!-- Bottom X-axis (Frequency) -->
                <ImageView
                    android:id="@+id/axis_x"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_below="@+id/visualizer_container"
                    android:layout_toEndOf="@+id/axis_y"
                    android:scaleType="fitXY" />

                <FrameLayout
                    android:id="@+id/visualizer_container"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_toEndOf="@+id/axis_y">

                    <!-- Regular frequency view -->
                    <LinearLayout
                        android:id="@+id/view_standard_freq"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="invisible">
                        <TextView
                            android:id="@+id/frequencyText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/frequency_text"
                            android:textSize="14sp" />
                        <ProgressBar
                            android:id="@+id/analysisProgress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="180dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Spectrogram view -->
                    <ImageView
                        android:id="@+id/view_spectrogram"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:scaleType="fitXY"
                        android:visibility="gone" />

                    <!-- Oscilloscope view -->
                    <ImageView
                        android:id="@+id/view_oscilloscope"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:scaleType="fitXY"
                        android:visibility="gone" />

                </FrameLayout>
            </RelativeLayout>

            <!-- GNSS Status Overlay (when monitoring is active) -->
            <LinearLayout
                android:id="@+id/layout_gnss_status_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:visibility="gone">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/textGnssStatusMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gnss_status_searching"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/textSatelliteCountMain"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/satellites_count"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/textAverageCn0Main"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_cn0"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/textInterferenceLevelMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/interference_normal"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnToggleTunnistus"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:layout_below="@id/statusCard"
        android:layout_marginTop="48dp"
        android:layout_centerHorizontal="true"
        android:minWidth="250dp"
        android:text="@string/start_detection"
        android:backgroundTint="@android:color/holo_green_dark"
        android:textSize="14sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_gnss_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnToggleTunnistus"
        android:layout_marginTop="4dp"
        android:layout_centerHorizontal="true"
        android:text="@string/bg_gnss_monitor"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/layout_bottom_menus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:maxWidth="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnGnssMonitor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/gps_live"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="4dp"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnOpenMap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/map"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/logs"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnMicSetup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/mic_setup"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnGpsSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/gnss_settings"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnGeneralSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/general_settings"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/alert_settings"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnManual"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/manual"
                android:layout_marginEnd="4dp"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnAbout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/about"
                android:layout_marginStart="4dp"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
